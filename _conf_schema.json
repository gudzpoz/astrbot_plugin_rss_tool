{
  "allow_agents": {
    "description": "是否允许 AstrBot 自主修改 RSS 订阅列表",
    "type": "bool",
    "default": true
  },
  "user_agent": {
    "description": "User-Agent",
    "type": "string",
    "default": "AstrBot-RSS-Tool"
  },
  "cleanup_days": {
    "description": "自动清除多少天前的旧条目（0 表示不清除）",
    "hint": "已读条目和已禁用订阅的未读条目在超过该天数后会被自动清除。",
    "type": "int",
    "default": 60
  },
  "feeds": {
    "description": "RSS 订阅列表",
    "hint": "若手动添加太麻烦，也可让 Agent 自动添加。",
    "type": "template_list",
    "templates": {
      "site": {
        "name": "订阅",
        "items": {
          "url": {
            "description": "Atom/RSS 订阅链接",
            "type": "string",
            "hint": "https://example.com/rss.xml"
          },
          "enabled": {
            "description": "是否启用",
            "type": "bool",
            "default": true
          },
          "title": {
            "description": "订阅名称",
            "type": "string"
          },
          "tags": {
            "description": "订阅标签",
            "type": "list"
          },
          "frequency_hours": {
            "description": "几小时更新一次",
            "type": "int",
            "default": 6
          }
        }
      }
    }
  },
  "max_rss_size_mb": {
    "description": "最大 RSS 下载大小",
    "hint": "避免恶意 RSS 的攻击，单位：MB（0 表示不限制）",
    "type": "int",
    "default": 10
  },
  "allow_custom_ports": {
    "description": "是否允许链接指定端口（有安全风险）",
    "type": "bool",
    "default": false
  }
}
